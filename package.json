{
    "name": "ai-live",
    "version": "0.2.0",
    "private": true,
    "description": "Host repository for the standalone genetic module sandbox",
    "engines": {
        "node": ">=20"
    },
    "workspaces": [
        "sandbox/genetic-module"
    ],
    "scripts": {
        "setup": "npm --prefix sandbox/genetic-module run setup",
        "status": "npm --prefix sandbox/genetic-module run status",
        "scan": "npm --prefix sandbox/genetic-module run scan",
        "resolve": "npm --prefix sandbox/genetic-module run resolve",
        "check": "npm --prefix sandbox/genetic-module run check --",
        "verify": "npm --prefix sandbox/genetic-module run verify"
    }
}
